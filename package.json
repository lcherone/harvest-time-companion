{
  "name": "harvest-time-companion",
  "version": "0.1.6",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/api",
    "packages/shared"
  ],
  "scripts": {
    "health": "node scripts/check-health.mjs",
    "service:install": "node scripts/install-service.mjs",
    "service:uninstall": "node scripts/install-service.mjs --uninstall",
    "smoke": "node scripts/smoke-test.mjs",
    "smoke:supervisor": "node scripts/supervisor-smoke-test.mjs",
    "start": "npm run start -w @harvest-time/api",
    "start:auto": "node scripts/supervisor.mjs",
    "update": "node scripts/update.mjs",
    "update:check": "node scripts/update.mjs --check"
  }
}
