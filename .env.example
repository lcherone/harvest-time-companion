NODE_ENV=production
HOST=127.0.0.1
PORT=8787
LOG_LEVEL=info

# Optional pre-pairing override for a self-hosted/unpacked extension.
# If blank, the first user-initiated manager launch safely pins the exact extension origin.
# Example: chrome-extension://abcdefghijklmnopabcdefghijklmnop
EXTENSION_ORIGIN=

# Optional Jira enrichment. Detection and mock timers work without this.
JIRA_VERIFY_ISSUES=false
JIRA_SITE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Optional live Harvest OAuth. Mock mode works without these values.
HARVEST_CLIENT_ID=
HARVEST_CLIENT_SECRET=
HARVEST_USER_AGENT=HarvestTime Companion (your-email@example.com)
HARVEST_REDIRECT_URI=http://127.0.0.1:8787/auth/harvest/callback
HARVEST_TOKEN_STORE_PATH=.harvest-time/oauth-token.json
